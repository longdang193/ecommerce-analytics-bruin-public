# Local developer credentials template
# Copy this file to .env.local and fill in your service account key.
# .env.local is gitignored — never commit credentials.
#
# Usage:
#   bruin run --environment dev .      (writes to de_pipeline_dev)
#   bruin run --environment prod .     (writes to de_pipeline)
#   bruin validate .                   (no credentials needed)
#
# The GCP_SERVICE_ACCOUNT_KEY must be the entire JSON content of your
# service account key file, on a single line or as a properly escaped string.

GCP_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"ecommerce-analytics-bruin",...}'
